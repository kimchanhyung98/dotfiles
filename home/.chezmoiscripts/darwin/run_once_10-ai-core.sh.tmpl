#!/bin/bash
#
# AI CLI 설치

{{ if ne .chezmoi.os "darwin" }}
exit 0
{{ end }}

set -eufo pipefail

echo "[ai-core][start]"

if ! command -v npm &>/dev/null; then
    echo "[ai-core][error] npm not found. Ensure Node.js was installed via Brewfile."
    exit 1
fi

# Claude Code
if ! command -v claude &>/dev/null; then
    echo "[ai-core][claude] installing"
    installer=$(mktemp)
    if curl -fsSL https://claude.ai/install.sh -o "$installer"; then
        bash "$installer" || echo "[ai-core][warning] Claude Code installation failed"
    else
        echo "[ai-core][warning] Claude Code download failed"
    fi
    rm -f "$installer"
else
    echo "[ai-core][claude] already installed ($(claude --version 2>/dev/null || echo 'unknown'))"
fi

# Codex CLI
if ! command -v codex &>/dev/null; then
    echo "[ai-core][codex] installing"
    npm install -g @openai/codex || echo "[ai-core][warning] Codex CLI installation failed"
else
    echo "[ai-core][codex] already installed ($(codex --version 2>/dev/null || echo 'unknown'))"
fi

# CodeGraph
# - Claude Code / Codex 공통 코드 인텔리전스 MCP 서버
if ! command -v codegraph &>/dev/null; then
    echo "[ai-core][codegraph] installing"
    NPM_CACHE_DIR="${TMPDIR:-/tmp}/dotfiles-npm-cache"
    mkdir -p "$NPM_CACHE_DIR"
    npm install -g @colbymchenry/codegraph@latest --cache "$NPM_CACHE_DIR" || echo "[ai-core][warning] CodeGraph installation failed"
    if ! command -v codegraph &>/dev/null; then
        echo "[ai-core][warning] CodeGraph command still not found after installation"
    fi
else
    echo "[ai-core][codegraph] already installed ($(codegraph --version 2>/dev/null || echo 'unknown'))"
fi

# Antigravity CLI
# - Google Antigravity 터미널 AI 에이전트 (바이너리: agy)
if ! command -v agy &>/dev/null; then
    echo "[ai-core][antigravity] installing"
    installer=$(mktemp)
    if curl -fsSL https://antigravity.google/cli/install.sh -o "$installer"; then
        bash "$installer" || echo "[ai-core][warning] Antigravity CLI installation failed"
    else
        echo "[ai-core][warning] Antigravity CLI download failed"
    fi
    rm -f "$installer"
else
    echo "[ai-core][antigravity] already installed ($(agy --version 2>/dev/null || echo 'unknown'))"
fi

# Hermes Agent
if ! command -v hermes &>/dev/null; then
    echo "[ai-core][hermes] installing"
    installer=$(mktemp)
    if curl -fsSL https://hermes-agent.nousresearch.com/install.sh -o "$installer"; then
        bash "$installer" --non-interactive --skip-setup || echo "[ai-core][warning] Hermes installation failed"
    else
        echo "[ai-core][warning] Hermes download failed"
    fi
    rm -f "$installer"
else
    echo "[ai-core][hermes] already installed ($(hermes --version 2>/dev/null || echo 'unknown'))"
fi

echo "[ai-core][done]"
