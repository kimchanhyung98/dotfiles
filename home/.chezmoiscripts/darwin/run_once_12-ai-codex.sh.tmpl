#!/bin/bash
#
# AI Codex: oh-my-codex, profile init

{{ if ne .chezmoi.os "darwin" }}
exit 0
{{ end }}

set -eufo pipefail

echo "[ai-codex][start]"

# oh-my-codex
# - Codex CLI 멀티 에이전트 오케스트레이션 (프롬프트, 스킬, 팀 실행)
if ! command -v omx &>/dev/null; then
    echo "[ai-codex][oh-my-codex] installing"
    npm install -g oh-my-codex || echo "[ai-codex][warning] oh-my-codex installation failed"
else
    echo "[ai-codex][oh-my-codex] already installed"
fi

# 초기 설정 및 검증
mkdir -p "$HOME/.codex"
if [ ! -f "$HOME/.codex/.profile-initialized" ]; then
    echo "[ai-codex][oh-my-codex] initializing"
    if omx setup --scope user 2>/dev/null && omx doctor 2>/dev/null; then
        touch "$HOME/.codex/.profile-initialized"
    else
        echo "[ai-codex][warning] omx setup/doctor failed"
    fi
fi

echo "[ai-codex][done]"
