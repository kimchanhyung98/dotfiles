#!/bin/bash
#
# Prerequisites: Xcode CLI Tools, Homebrew, zerobrew, Rosetta 2 (Apple Silicon)

{{ if ne .chezmoi.os "darwin" }}
exit 0
{{ end }}

set -eufo pipefail

echo "[prerequisites][start]"

# 1. Xcode Command Line Tools
# - macOS 개발 도구 (git, make 등) 설치
if ! xcode-select -p &>/dev/null; then
    echo "[prerequisites][xcode-cli] installing"
    xcode-select --install
    echo "[prerequisites][xcode-cli] waiting (up to 10 minutes)"
    attempt=0
    while ! xcode-select -p &>/dev/null; do
        attempt=$((attempt + 1))
        if [ "$attempt" -ge 120 ]; then
            echo "[prerequisites][error] Xcode Command Line Tools installation timed out" >&2
            echo "[prerequisites][manual] complete the installer, then re-run chezmoi apply" >&2
            exit 1
        fi
        sleep 5
    done
else
    echo "[prerequisites][xcode-cli] already installed"
fi

# 2. Homebrew
# - macOS 패키지 매니저 설치
if ! command -v brew &>/dev/null; then
    echo "[prerequisites][homebrew] installing"
    # Homebrew 공식 부트스트랩 명령으로 설치 (의도적으로 curl | bash 사용)
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
    {{ if .isAppleSilicon }}
    eval "$(/opt/homebrew/bin/brew shellenv)"
    {{ else }}
    eval "$(/usr/local/bin/brew shellenv)"
    {{ end }}
else
    echo "[prerequisites][homebrew] already installed"
fi

# 3. zerobrew
# - Homebrew 대안 패키지 매니저 (빠른 설치 지원)
ensure_zb_available() {
    if command -v zb &>/dev/null; then
        return 0
    fi
    # - 여러 설치 경로에서 zb 바이너리 탐색
    for candidate in "$HOME/.local/bin/zb" "/opt/zerobrew/bin/zb" "/usr/local/zerobrew/bin/zb"; do
        if [ -x "$candidate" ]; then
            local dir
            dir="$(dirname "$candidate")"
            export PATH="$dir:$PATH"
            return 0
        fi
    done
    return 1
}

if ! ensure_zb_available; then
    echo "[prerequisites][zerobrew] installing"
    installer=$(mktemp)
    if curl -fsSL https://zerobrew.rs/install -o "$installer"; then
        bash "$installer" || echo "[prerequisites][warning] zerobrew installation failed"
    else
        echo "[prerequisites][warning] zerobrew download failed"
    fi
    rm -f "$installer"
fi

if ensure_zb_available; then
    echo "[prerequisites][zerobrew] ready ($(command -v zb))"
else
    echo "[prerequisites][warning] zerobrew not available. Homebrew will be used as fallback."
fi

{{ if .isAppleSilicon }}
# 4. Rosetta 2 (Apple Silicon 전용)
# - x86_64 바이너리를 ARM에서 실행하기 위한 호환 레이어
if ! pkgutil --pkgs 2>/dev/null | grep -q "com.apple.pkg.RosettaUpdateAuto"; then
    echo "[prerequisites][rosetta] installing"
    /usr/sbin/softwareupdate --install-rosetta --agree-to-license
else
    echo "[prerequisites][rosetta] already installed"
fi
{{ end }}

# 5. GitHub SSH known_hosts
# - 새 환경에서 SSH 호스트 키 검증 프롬프트 방지
SSH_DIR="$HOME/.ssh"
KNOWN_HOSTS="$SSH_DIR/known_hosts"
mkdir -p "$SSH_DIR"
chmod 700 "$SSH_DIR"
if command -v ssh-keyscan &>/dev/null; then
    if ! ssh-keygen -F github.com -f "$KNOWN_HOSTS" >/dev/null 2>&1; then
        echo "[prerequisites][github-ssh] fetching and verifying host keys"
        scanned_keys=$(mktemp)
        verified_keys=$(mktemp)
        if ssh-keyscan -T 10 -t ed25519,ecdsa,rsa github.com >"$scanned_keys" 2>/dev/null; then
            while IFS= read -r key_line; do
                [ -n "$key_line" ] || continue
                fingerprint="$(printf '%s\n' "$key_line" | ssh-keygen -E sha256 -lf - 2>/dev/null | awk '{print $2}' || true)"
                case "$fingerprint" in
                    SHA256:+DiY3wvvV6TuJJhbpZisF/zLDA0zPMSvHdkr4UvCOqU | \
                    SHA256:p2QAMXNIC1TJYWeIOttrVc98/R1BUFWu3/LiyKgUfQM | \
                    SHA256:uNiVztksCsDhcc0u9e8BujQXVUpKZIDTMczCvj3tD2s)
                        printf '%s\n' "$key_line" >>"$verified_keys"
                        ;;
                    *)
                        echo "[prerequisites][warning] rejected unrecognized GitHub host key: ${fingerprint:-unknown}" >&2
                        ;;
                esac
            done <"$scanned_keys"
        fi
        if [ -s "$verified_keys" ]; then
            cat "$verified_keys" >>"$KNOWN_HOSTS"
            chmod 600 "$KNOWN_HOSTS"
        else
            echo "[prerequisites][warning] Failed to fetch verified GitHub host keys; continuing."
        fi
        rm -f "$scanned_keys" "$verified_keys"
    else
        echo "[prerequisites][github-ssh] already registered"
    fi
else
    echo "[prerequisites][warning] ssh-keyscan not found."
fi

echo "[prerequisites][done]"
