#!/bin/bash
#
# AI Claude: SuperClaude

{{ if ne .chezmoi.os "darwin" }}
exit 0
{{ end }}

set -eufo pipefail

echo "[ai-claude][start]"

# SuperClaude
# - Claude Code 확장 프레임워크 (페르소나, 명령어, 플래그 시스템)
if ! command -v superclaude &>/dev/null; then
    echo "[ai-claude][superclaude] installing"
    if pipx install superclaude; then
        SuperClaude install --force --yes || echo "[ai-claude][warning] SuperClaude post-install setup failed"
    else
        echo "[ai-claude][warning] SuperClaude installation failed (requires pipx)"
    fi
else
    echo "[ai-claude][superclaude] already installed"
fi

# CodeGraph MCP
# - Claude Code용 로컬 코드 인텔리전스 서버
if ! claude mcp list 2>/dev/null | grep -q "codegraph"; then
    if command -v codegraph &>/dev/null; then
        echo "[ai-claude][codegraph-mcp] adding"
        MCP_JSON=$(jq -n '{type:"stdio",command:"codegraph",args:["serve","--mcp"]}')
        claude mcp add-json codegraph --scope user "$MCP_JSON" || echo "[ai-claude][warning] CodeGraph MCP addition failed"
    else
        echo "[ai-claude][warning] CodeGraph not found, skipping MCP registration"
    fi
else
    echo "[ai-claude][codegraph-mcp] already configured"
fi

echo "[ai-claude][done]"
