#!/bin/bash
#
# Install/sync packages from Brewfile
# Re-runs when Brewfile content changes
#
# Brewfile hash: {{ include "Brewfile" | sha256sum }}

{{ if ne .chezmoi.os "darwin" }}
exit 0
{{ end }}

set -eufo pipefail

echo "[brew-packages][start]"

# Homebrew 환경 변수 로드
{{ $homebrewPrefix := .homebrewPrefix }}
eval "$({{ $homebrewPrefix }}/bin/brew shellenv)"

# Brewfile 기반 패키지 일괄 설치/동기화 (zerobrew 우선, Homebrew 폴백)
BREWFILE="{{ .chezmoi.sourceDir }}/Brewfile"

ensure_zb_available() {
    local candidate_dir
    if command -v zb &>/dev/null; then
        return 0
    fi
    if [ -n "${ZEROBREW_PREFIX:-}" ] && [ -x "$ZEROBREW_PREFIX/bin/zb" ]; then
        export PATH="$ZEROBREW_PREFIX/bin:$PATH"
        return 0
    fi
    for candidate in "$HOME/.local/bin/zb" "/opt/zerobrew/bin/zb" "/usr/local/zerobrew/bin/zb"; do
        if [ -x "$candidate" ]; then
            candidate_dir="$(dirname "$candidate")"
            export PATH="$candidate_dir:$PATH"
            return 0
        fi
    done
    return 1
}

run_homebrew_bundle() {
    local bundle_file="${1:-$BREWFILE}"
    local brew_skip="${HOMEBREW_BUNDLE_BREW_SKIP:-}"

    if grep -Fq 'brew "dopplerhq/cli/doppler"' "$bundle_file"; then
        if ! brew tap dopplerhq/cli; then
            echo "[brew-packages][error] failed to tap Doppler repository" >&2
            exit 1
        fi
        if ! brew trust --formula dopplerhq/cli/doppler; then
            echo "[brew-packages][error] failed to trust Doppler formula" >&2
            exit 1
        fi
    fi
    if grep -Fq 'brew "xcodes"' "$bundle_file" &&
        brew list --formula --versions xcodes >/dev/null 2>&1; then
        case " $brew_skip " in
            *" xcodes "*) ;;
            *) brew_skip="${brew_skip:+$brew_skip }xcodes" ;;
        esac
    fi
    if ! HOMEBREW_BUNDLE_BREW_SKIP="$brew_skip" brew bundle --file="$bundle_file"; then
        echo "[brew-packages][error] brew bundle failed"
        exit 1
    fi
}

upgrade_zerobrew_formulas() {
    local bundle_file="$1"
    local allowed_formulas installed_formulas formula _version
    local -a upgrade_formulas=()

    allowed_formulas="$(sed -nE 's/^brew "([^"]+)".*$/\1/p' "$bundle_file")" || return 1
    installed_formulas="$(zb list)" || return 1
    if [ "$installed_formulas" = "No formulas installed." ]; then
        return 0
    fi

    while read -r formula _version; do
        case "$formula" in
            "") continue ;;
        esac
        case "
$allowed_formulas
" in
            *"
$formula
"*) upgrade_formulas+=("$formula") ;;
        esac
    done <<< "$installed_formulas"

    if [ "${#upgrade_formulas[@]}" -gt 0 ]; then
        zb upgrade "${upgrade_formulas[@]}"
    fi
}

bundle_is_satisfied() {
    brew bundle check --no-upgrade --file="$BREWFILE" >/dev/null
}

if ensure_zb_available; then
    echo "[brew-packages][zerobrew] initialize and bundle install"
    ZB_BREWFILE="$(mktemp)"
    HOMEBREW_ONLY_BREWFILE="$(mktemp)"
    trap 'rm -f "$ZB_BREWFILE" "$HOMEBREW_ONLY_BREWFILE"' EXIT
    # ruby(zerobrew#286), xcodes, cask는 Homebrew가 소유한다.
    sed -E -e '/^brew "(ruby|xcodes)"/d' -e '/^cask /d' \
        "$BREWFILE" > "$ZB_BREWFILE"
    sed -nE -e '/^brew "(ruby|xcodes)"/p' -e '/^cask /p' \
        "$BREWFILE" > "$HOMEBREW_ONLY_BREWFILE"
    if zb init --no-modify-path &&
        upgrade_zerobrew_formulas "$ZB_BREWFILE" &&
        zb bundle install -f "$ZB_BREWFILE"; then
        run_homebrew_bundle "$HOMEBREW_ONLY_BREWFILE"
        echo "[brew-packages][done]"
        exit 0
    fi
    echo "[brew-packages][warning] zerobrew bundle failed; falling back to Homebrew"
else
    echo "[brew-packages][warning] zerobrew not found; using Homebrew"
fi

run_homebrew_bundle

if ! bundle_is_satisfied; then
    echo "[brew-packages][error] Brewfile is not fully satisfied after synchronization" >&2
    exit 1
fi

echo "[brew-packages][done]"
