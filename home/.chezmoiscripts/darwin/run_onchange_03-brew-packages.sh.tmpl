#!/bin/bash
#
# Install/sync packages from Brewfile
# Re-runs when Brewfile content changes
#
# Brewfile hash: {{ include "Brewfile" | sha256sum }}

{{ if ne .chezmoi.os "darwin" }}
exit 0
{{ end }}

set -eufo pipefail

echo "[brew-packages][start]"

# Homebrew 환경 변수 로드
{{ $homebrewPrefix := .homebrewPrefix }}
eval "$({{ $homebrewPrefix }}/bin/brew shellenv)"

# Brewfile 기반 패키지 일괄 설치/동기화 (zerobrew 우선, Homebrew 폴백)
BREWFILE="{{ .chezmoi.sourceDir }}/Brewfile"

ensure_zb_available() {
    local candidate_dir
    if command -v zb &>/dev/null; then
        return 0
    fi
    if [ -n "${ZEROBREW_PREFIX:-}" ] && [ -x "$ZEROBREW_PREFIX/bin/zb" ]; then
        export PATH="$ZEROBREW_PREFIX/bin:$PATH"
        return 0
    fi
    for candidate in "$HOME/.local/bin/zb" "/opt/zerobrew/bin/zb" "/usr/local/zerobrew/bin/zb"; do
        if [ -x "$candidate" ]; then
            candidate_dir="$(dirname "$candidate")"
            export PATH="$candidate_dir:$PATH"
            return 0
        fi
    done
    return 1
}

run_homebrew_bundle() {
    local brew_skip="${HOMEBREW_BUNDLE_BREW_SKIP:-}"

    if ! brew tap dopplerhq/cli; then
        echo "[brew-packages][error] failed to tap Doppler repository" >&2
        exit 1
    fi
    if ! brew trust --formula dopplerhq/cli/doppler; then
        echo "[brew-packages][error] failed to trust Doppler formula" >&2
        exit 1
    fi
    if brew list --formula --versions xcodes >/dev/null 2>&1; then
        case " $brew_skip " in
            *" xcodes "*) ;;
            *) brew_skip="${brew_skip:+$brew_skip }xcodes" ;;
        esac
    fi
    if ! HOMEBREW_BUNDLE_BREW_SKIP="$brew_skip" brew bundle --file="$BREWFILE"; then
        echo "[brew-packages][error] brew bundle failed"
        exit 1
    fi
}

bundle_is_satisfied() {
    brew bundle check --no-upgrade --file="$BREWFILE" >/dev/null
}

if ensure_zb_available; then
    echo "[brew-packages][zerobrew] initialize and bundle install"
    if zb init --no-modify-path && zb bundle install -f "$BREWFILE"; then
        echo "[brew-packages][done]"
        exit 0
    fi
    echo "[brew-packages][warning] zerobrew bundle failed; falling back to Homebrew"
else
    echo "[brew-packages][warning] zerobrew not found; using Homebrew"
fi

run_homebrew_bundle

if ! bundle_is_satisfied; then
    echo "[brew-packages][error] Brewfile is not fully satisfied after synchronization" >&2
    exit 1
fi

echo "[brew-packages][done]"
