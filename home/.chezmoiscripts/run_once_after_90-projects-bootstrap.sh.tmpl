#!/bin/bash
# Bootstrap public GitHub repositories on the first chezmoi apply.

set -u

projects_bootstrap="$HOME/.local/bin/projects-bootstrap"
github_name={{ .name | quote }}

if [ ! -x "$projects_bootstrap" ]; then
    echo "[projects-bootstrap-once][error] helper missing or not executable: $projects_bootstrap" >&2
    exit 0
fi

if ! "$projects_bootstrap" "$github_name"; then
    echo "[projects-bootstrap-once][warning] retry manually: projects-bootstrap '$github_name'" >&2
fi
