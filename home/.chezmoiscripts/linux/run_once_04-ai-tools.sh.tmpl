#!/bin/bash
#
# AI Tools and extensions (Linux): claude, codex, codegraph, hermes, oh-my-codex, opencode, oh-my-opencode, gemini
# Runs once on first setup

{{ if ne .chezmoi.os "linux" }}
exit 0
{{ end }}

set -eufo pipefail

echo "[ai-tools][start]"

# npm 사전 확인
if ! command -v npm &>/dev/null; then
    echo "[ai-tools][error] npm not found. Install Node.js first."
    exit 1
fi

# Claude Code
# - Anthropic Claude 터미널 AI 코딩 도우미
if ! command -v claude &>/dev/null; then
    echo "[ai-tools][claude] installing"
    installer=$(mktemp)
    if curl -fsSL https://claude.ai/install.sh -o "$installer"; then
        bash "$installer" || echo "[ai-tools][warning] Claude Code installation failed"
    else
        echo "[ai-tools][warning] Claude Code download failed"
    fi
    rm -f "$installer"
else
    echo "[ai-tools][claude] already installed ($(claude --version 2>/dev/null || echo 'unknown'))"
fi

# Codex CLI
# - OpenAI Codex 터미널 AI 코딩 도우미
if ! command -v codex &>/dev/null; then
    echo "[ai-tools][codex] installing"
    npm install -g @openai/codex || echo "[ai-tools][warning] Codex install failed"
else
    echo "[ai-tools][codex] already installed"
fi

# CodeGraph
# - Claude Code / Codex 공통 코드 인텔리전스 MCP 서버
if ! command -v codegraph &>/dev/null; then
    echo "[ai-tools][codegraph] installing"
    npm install -g @colbymchenry/codegraph || echo "[ai-tools][warning] CodeGraph install failed"
else
    echo "[ai-tools][codegraph] already installed"
fi

# CodeGraph MCP (Claude)
# - Claude Code용 로컬 코드 인텔리전스 서버 등록 (Codex는 config.toml로 선언적 관리)
if command -v claude &>/dev/null && command -v codegraph &>/dev/null; then
    if ! claude mcp list 2>/dev/null | grep -q "codegraph"; then
        echo "[ai-tools][codegraph-mcp] adding"
        claude mcp add-json codegraph --scope user '{"type":"stdio","command":"codegraph","args":["serve","--mcp"]}' || echo "[ai-tools][warning] CodeGraph MCP addition failed"
    else
        echo "[ai-tools][codegraph-mcp] already configured"
    fi
else
    echo "[ai-tools][codegraph-mcp] claude or codegraph not found, skipping MCP registration"
fi

# oh-my-codex
# - Codex CLI 확장 프레임워크
if ! command -v omx &>/dev/null; then
    echo "[ai-tools][oh-my-codex] installing"
    npm install -g oh-my-codex || echo "[ai-tools][warning] oh-my-codex install failed"
else
    echo "[ai-tools][oh-my-codex] already installed"
fi

# OpenCode
# - 오픈소스 터미널 AI 코딩 도우미
if ! command -v opencode &>/dev/null; then
    echo "[ai-tools][opencode] installing"
    npm install -g opencode-ai || echo "[ai-tools][warning] OpenCode install failed"
else
    echo "[ai-tools][opencode] already installed"
fi

# oh-my-opencode
# - OpenCode 확장 프레임워크
if ! command -v oh-my-opencode &>/dev/null; then
    echo "[ai-tools][oh-my-opencode] installing"
    npm install -g oh-my-opencode || echo "[ai-tools][warning] oh-my-opencode install failed"
else
    echo "[ai-tools][oh-my-opencode] already installed"
fi

# Gemini CLI
# - Google Gemini 터미널 AI 도우미
if ! command -v gemini &>/dev/null; then
    echo "[ai-tools][gemini] installing"
    npm install -g @google/gemini-cli || echo "[ai-tools][warning] Gemini CLI install failed"
else
    echo "[ai-tools][gemini] already installed"
fi

# Hermes Agent
# - Nous Research Hermes 터미널 AI 에이전트
if ! command -v hermes &>/dev/null; then
    echo "[ai-tools][hermes] installing"
    installer=$(mktemp)
    if curl -fsSL https://hermes-agent.nousresearch.com/install.sh -o "$installer"; then
        bash "$installer" --non-interactive --skip-setup || echo "[ai-tools][warning] Hermes install failed"
    else
        echo "[ai-tools][warning] Hermes download failed"
    fi
    rm -f "$installer"
else
    echo "[ai-tools][hermes] already installed ($(hermes --version 2>/dev/null || echo 'unknown'))"
fi

echo "[ai-tools][done]"
