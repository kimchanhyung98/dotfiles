#!/bin/bash
#
# AI Tools and extensions (Linux): required claude/codex, optional integrations
# Runs once on first setup

{{ if ne .chezmoi.os "linux" }}
exit 0
{{ end }}

set -eufo pipefail

echo "[ai-tools][start]"

export PATH="$HOME/.local/bin:$HOME/.claude/local/bin:$PATH"

# Claude Code
# - Anthropic Claude 터미널 AI 코딩 도우미
if ! command -v claude &>/dev/null; then
    echo "[ai-tools][claude] installing"
    installer=$(mktemp)
    if ! curl -fsSL https://claude.ai/install.sh -o "$installer"; then
        rm -f "$installer"
        echo "[ai-tools][error] Claude Code download failed" >&2
        exit 1
    fi
    if ! bash "$installer"; then
        rm -f "$installer"
        echo "[ai-tools][error] Claude Code installation failed" >&2
        exit 1
    fi
    rm -f "$installer"
else
    echo "[ai-tools][claude] already installed ($(claude --version 2>/dev/null || echo 'unknown'))"
fi
if ! command -v claude &>/dev/null; then
    echo "[ai-tools][error] claude command not found after installation" >&2
    exit 1
fi

# Codex CLI
# - OpenAI Codex 터미널 AI 코딩 도우미
if ! command -v codex &>/dev/null; then
    echo "[ai-tools][codex] installing"
    installer=$(mktemp)
    if ! curl -fsSL https://chatgpt.com/codex/install.sh -o "$installer"; then
        rm -f "$installer"
        echo "[ai-tools][error] Codex download failed" >&2
        exit 1
    fi
    if ! CODEX_NON_INTERACTIVE=1 sh "$installer"; then
        rm -f "$installer"
        echo "[ai-tools][error] Codex installation failed" >&2
        exit 1
    fi
    rm -f "$installer"
else
    echo "[ai-tools][codex] already installed"
fi
if ! command -v codex &>/dev/null; then
    echo "[ai-tools][error] codex command not found after installation" >&2
    exit 1
fi

# CodeGraph
# - Claude Code / Codex 공통 코드 인텔리전스 MCP 서버
if ! command -v npm &>/dev/null; then
    echo "[ai-tools][warning] npm not found; skipping optional CodeGraph installation"
elif ! command -v codegraph &>/dev/null; then
    echo "[ai-tools][codegraph] installing"
    NPM_CACHE_DIR="${TMPDIR:-/tmp}/dotfiles-npm-cache"
    mkdir -p "$NPM_CACHE_DIR"
    npm install -g @colbymchenry/codegraph@latest --cache "$NPM_CACHE_DIR" || echo "[ai-tools][warning] CodeGraph install failed"
    if ! command -v codegraph &>/dev/null; then
        echo "[ai-tools][warning] CodeGraph command still not found after installation"
    fi
else
    echo "[ai-tools][codegraph] already installed"
fi

# CodeGraph MCP (Claude)
# - Claude Code용 로컬 코드 인텔리전스 서버 등록 (Codex는 config.toml로 선언적 관리)
if command -v claude &>/dev/null && command -v codegraph &>/dev/null; then
    if ! claude mcp list 2>/dev/null | grep -q "codegraph"; then
        echo "[ai-tools][codegraph-mcp] adding"
        claude mcp add-json codegraph --scope user '{"type":"stdio","command":"codegraph","args":["serve","--mcp"]}' || echo "[ai-tools][warning] CodeGraph MCP addition failed"
    else
        echo "[ai-tools][codegraph-mcp] already configured"
    fi
else
    echo "[ai-tools][codegraph-mcp] claude or codegraph not found, skipping MCP registration"
fi

# GitHub Copilot CLI (optional; Claude and Codex are the required AI CLIs)
if ! command -v copilot &>/dev/null; then
    echo "[ai-tools][copilot] installing"
    installer=$(mktemp)
    if curl -fsSL https://gh.io/copilot-install -o "$installer"; then
        PREFIX="$HOME/.local" bash "$installer" || echo "[ai-tools][warning] Copilot CLI installation failed"
    else
        echo "[ai-tools][warning] Copilot CLI download failed"
    fi
    rm -f "$installer"
else
    echo "[ai-tools][copilot] already installed"
fi

# Antigravity CLI
# - Google Antigravity 터미널 AI 에이전트 (바이너리: agy)
if ! command -v agy &>/dev/null; then
    echo "[ai-tools][antigravity] installing"
    installer=$(mktemp)
    if curl -fsSL https://antigravity.google/cli/install.sh -o "$installer"; then
        bash "$installer" || echo "[ai-tools][warning] Antigravity CLI install failed"
    else
        echo "[ai-tools][warning] Antigravity CLI download failed"
    fi
    rm -f "$installer"
else
    echo "[ai-tools][antigravity] already installed ($(agy --version 2>/dev/null || echo 'unknown'))"
fi

# Hermes Agent
# - Nous Research Hermes 터미널 AI 에이전트
if ! command -v hermes &>/dev/null; then
    echo "[ai-tools][hermes] installing"
    installer=$(mktemp)
    if curl -fsSL https://hermes-agent.nousresearch.com/install.sh -o "$installer"; then
        bash "$installer" --non-interactive --skip-setup || echo "[ai-tools][warning] Hermes install failed"
    else
        echo "[ai-tools][warning] Hermes download failed"
    fi
    rm -f "$installer"
else
    echo "[ai-tools][hermes] already installed ($(hermes --version 2>/dev/null || echo 'unknown'))"
fi

echo "[ai-tools][done]"
