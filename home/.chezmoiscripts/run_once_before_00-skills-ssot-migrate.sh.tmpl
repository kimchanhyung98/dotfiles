#!/bin/bash
#
# 스킬 SSOT 전환 준비 (darwin/linux 공통)
# - Claude Code와 Codex의 skills 경로가 symlink 전환 이전의 실제 디렉터리면 삭제한다.
#   기존 디렉터리를 제거해야 chezmoi가 ~/.skills symlink를 생성할 수 있다.
# - 모든 경로가 이미 symlink 인 머신에서는 아무 일도 하지 않는다 (멱등).

# 주의: 이 스크립트는 glob 순회가 필요하므로 -f(noglob)를 켜지 않는다
set -euo pipefail

for dir in \
    "$HOME/.claude/skills" \
    "$HOME/.agents/skills" \
    "$HOME/.codex/skills"; do
    if [ ! -d "$dir" ] || [ -L "$dir" ]; then
        continue
    fi

    echo "[skills-migrate] remove $dir"
    rm -rf "$dir"
done
