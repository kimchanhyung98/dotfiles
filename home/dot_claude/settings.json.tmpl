{{- /* ~/.claude/settings.json — Claude Code 핵심 설정 (권한, 플러그인, 훅) */ -}}
{
  "respectGitignore": true,
  "cleanupPeriodDays": 21,
  "attribution": {
    "commit": "Co-Authored-By: Claude <noreply@anthropic.com>",
    "pr": ""
  },
  "permissions": {
    "defaultMode": "bypassPermissions",
    "deny": [
      "Read(.env)",
      "Read(.env.prod*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/*.p12)",
      "Read(**/*.pfx)",
      "Read(**/*.crt)",
      "Read(**/*.cer)",
      "Read(**/*.jks)",
      "Read(**/*.keystore)",
      "Read(**/*.tfvars)",
      "Read(**/id_rsa*)",
      "Read(**/id_ed25519*)",
      "Read(**/.ssh/*)",
      "Read(**/.aws/*)",
      "Read(**/credentials.json)",
      "Edit(../**)",
      "Write(../**)"
    ]
  },
  "enabledPlugins": {
    "agent-browser@agent-browser": false,
