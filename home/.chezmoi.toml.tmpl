{{/* chezmoi 설정 템플릿 */}}
{{/* macOS (Intel & Apple Silicon) 및 Linux 지원 */}}

{{/* 최초 설정에는 이름, 이메일, 기기명이 필요하다. Codespaces는 공식 환경 변수를 사용한다. */}}
{{- $hasRequiredData := and (hasKey . "name") (hasKey . "email") (hasKey . "deviceName") -}}
{{- $isCodespaces := and (eq .chezmoi.os "linux") (eq (env "CODESPACES") "true") -}}
{{- if and (not stdinIsATTY) (not $hasRequiredData) (not $isCodespaces) -}}
{{-   fail "Initial configuration requires an interactive terminal to enter name, email, and device name" -}}
{{- end -}}
{{- $name := "" -}}
{{- $email := "" -}}
{{- $deviceName := "" -}}

{{/* macOS 아키텍처 감지 (Apple Silicon 여부) */}}
{{- $isAppleSilicon := false -}}
{{- if eq .chezmoi.os "darwin" -}}
{{-   if eq .chezmoi.arch "arm64" -}}
{{-     $isAppleSilicon = true -}}
{{-   end -}}
{{- end -}}

{{/* Homebrew 설치 경로 (설치되어 있으면 brew --prefix, 아니면 아키텍처 기본값) */}}
{{- $homebrewPrefix := "/usr/local" -}}
{{- if $isAppleSilicon -}}
{{-   $homebrewPrefix = "/opt/homebrew" -}}
{{- end -}}
{{- if and (eq .chezmoi.os "darwin") (lookPath "brew") -}}
{{-   $detectedPrefix := output "/bin/sh" "-c" "brew --prefix 2>/dev/null || true" | trim -}}
{{-   if $detectedPrefix -}}
{{-     $homebrewPrefix = $detectedPrefix -}}
{{-   end -}}
{{- end -}}

{{/* macOS에서 안정적인 호스트네임 가져오기 (scutil 사용) */}}
{{- $hostname := .chezmoi.hostname -}}
{{- if eq .chezmoi.os "darwin" -}}
{{-   if lookPath "scutil" -}}
{{-     $scutilHost := output "/bin/sh" "-c" "scutil --get LocalHostName 2>/dev/null || true" | trim -}}
{{-     if $scutilHost -}}
{{-       $hostname = $scutilHost -}}
{{-     end -}}
{{-   end -}}
{{- end -}}

{{/* 이름/이메일/기기명 수집 (Codespaces 자동 설치 또는 최초 대화형 실행) */}}
{{- if and $isCodespaces (not $hasRequiredData) -}}
{{-   $name = env "GITHUB_USER" | trim -}}
{{-   $email = env "GIT_COMMITTER_EMAIL" | trim -}}
{{-   $deviceName = env "CODESPACE_NAME" | trim -}}
{{-   if eq $name "" -}}
{{-     fail "GITHUB_USER is required for initial GitHub Codespaces configuration" -}}
{{-   end -}}
{{-   if eq $email "" -}}
{{-     fail "GIT_COMMITTER_EMAIL is required for initial GitHub Codespaces configuration" -}}
{{-   end -}}
{{-   if eq $deviceName "" -}}
{{-     fail "CODESPACE_NAME is required for initial GitHub Codespaces configuration" -}}
{{-   end -}}
{{- else -}}
{{-   $name = promptStringOnce . "name" "Name (GitHub username and Git author)" | trim -}}
{{-   if eq $name "" -}}
{{-     fail "Name is required" -}}
{{-   end -}}
{{-   $email = promptStringOnce . "email" "Email address" | trim -}}
{{-   if eq $email "" -}}
{{-     fail "Email address is required" -}}
{{-   end -}}
{{-   $deviceName = promptStringOnce . "deviceName" "Device name (tokscale 식별용)" | trim -}}
{{-   if eq $deviceName "" -}}
{{-     fail "Device name is required" -}}
{{-   end -}}
{{- end -}}

# chezmoi 소스 디렉토리 경로
sourceDir = {{ .chezmoi.sourceDir | quote }}

# 템플릿 데이터 (스크립트/설정에서 사용)
[data]
    name = {{ $name | quote }}
    email = {{ $email | quote }}
    hostname = {{ $hostname | quote }}
    deviceName = {{ $deviceName | quote }}
    isAppleSilicon = {{ $isAppleSilicon }}
    homebrewPrefix = {{ $homebrewPrefix | quote }}
