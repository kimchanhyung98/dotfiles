#!/bin/bash
#
# dotfiles-doctor — Health check for dotfiles installation
# Usage: dotfiles-doctor

set -uo pipefail

GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

pass=0
fail=0

check() {
    local label="$1"
    local cmd="$2"
    if eval "$cmd" &>/dev/null; then
        echo -e "  ${GREEN}✓${NC} $label"
        pass=$((pass + 1))
    else
        echo -e "  ${RED}✗${NC} $label"
        fail=$((fail + 1))
    fi
}

check_optional() {
    local label="$1"
    local cmd="$2"
    if eval "$cmd" &>/dev/null; then
        echo -e "  ${GREEN}✓${NC} $label"
        pass=$((pass + 1))
    else
        echo -e "  ${YELLOW}○${NC} $label (optional)"
    fi
}

check_version() {
    local label="$1"
    local cmd="$2"
    if command -v "$(echo "$cmd" | awk '{print $1}')" &>/dev/null; then
        local ver
        ver=$(eval "$cmd" 2>/dev/null | head -1 || echo "unknown")
        echo -e "  ${GREEN}✓${NC} $label ($ver)"
        pass=$((pass + 1))
    else
        echo -e "  ${RED}✗${NC} $label"
        fail=$((fail + 1))
    fi
}

check_version_optional() {
    local label="$1"
    local cmd="$2"
    if command -v "$(echo "$cmd" | awk '{print $1}')" &>/dev/null; then
        local ver
        ver=$(eval "$cmd" 2>/dev/null | head -1 || echo "unknown")
        echo -e "  ${GREEN}✓${NC} $label ($ver)"
        pass=$((pass + 1))
    else
        echo -e "  ${YELLOW}○${NC} $label (optional)"
    fi
}

check_path() {
    local label="$1"
    local path="$2"
    if [ -e "$path" ]; then
        echo -e "  ${GREEN}✓${NC} $label"
        pass=$((pass + 1))
    else
        echo -e "  ${RED}✗${NC} $label — $path"
        fail=$((fail + 1))
    fi
}

check_symlink() {
    local label="$1"
    local path="$2"
    local expected_target="$3"
    if [ -L "$path" ] && [ "$(readlink "$path")" = "$expected_target" ] && [ -e "$path" ]; then
        echo -e "  ${GREEN}✓${NC} $label"
        pass=$((pass + 1))
    else
        echo -e "  ${RED}✗${NC} $label — $path -> $expected_target"
        fail=$((fail + 1))
    fi
}

section() {
    echo -e "\n${BLUE}[$1]${NC}"
}

echo "=== dotfiles-doctor ==="
echo "$(date '+%Y-%m-%d %H:%M:%S')"

# System
section "System"
OS=$(uname -s)
ARCH=$(uname -m)
if [ "$OS" = "Darwin" ]; then
    echo -e "  ${GREEN}✓${NC} macOS $(sw_vers -productVersion) ($ARCH)"
    pass=$((pass + 1))
elif [ "$OS" = "Linux" ] && [ -r /etc/os-release ]; then
    linux_id="$(sed -n 's/^ID=//p' /etc/os-release | tr -d '"')"
    linux_version="$(sed -n 's/^VERSION_ID=//p' /etc/os-release | tr -d '"')"
    if [ "${CODESPACES:-false}" = "true" ] && [ "$linux_id" = "ubuntu" ]; then
        echo -e "  ${GREEN}✓${NC} GitHub Codespaces (Ubuntu ${linux_version:-unknown}, $ARCH)"
        pass=$((pass + 1))
    elif [ "${CODESPACES:-false}" = "true" ]; then
        echo -e "  ${RED}✗${NC} unsupported Codespaces distribution: ${linux_id:-unknown}"
        fail=$((fail + 1))
    elif [ "$linux_id" = "ubuntu" ] && [ "$linux_version" = "26.04" ]; then
        echo -e "  ${GREEN}✓${NC} Ubuntu 26.04 LTS ($ARCH)"
        pass=$((pass + 1))
    else
        echo -e "  ${RED}✗${NC} unsupported Linux: ${linux_id:-unknown} ${linux_version:-unknown}"
        fail=$((fail + 1))
    fi
else
    echo -e "  ${RED}✗${NC} unsupported system: $OS ($ARCH)"
    fail=$((fail + 1))
fi

# Shell
section "Shell"
check_version "zsh" "zsh --version"
check_version "git" "git --version"
check_version "vim" "vim --version"
check_optional "tmux" "command -v tmux"

# Terminal
section "Terminal"
check_optional "ghostty" "command -v ghostty"

# Languages
section "Languages"
check_version_optional "node" "node --version"
check_version_optional "python3" "python3 --version"
check_version_optional "go" "go version"
check_version_optional "rustc" "rustc --version"
check_version_optional "php" "php --version"
check_version_optional "ruby" "ruby --version"

# Package Managers
section "Package Managers"
check_optional "brew" "command -v brew"
check_optional "zb" "command -v zb"
check_optional "pipx" "command -v pipx"
check_optional "bun" "command -v bun"
check "doppler" "command -v doppler"

# AI CLI
section "AI CLI"
check "claude" "command -v claude"
check "codex" "command -v codex"
check_optional "copilot" "command -v copilot"
check_optional "codegraph" "command -v codegraph"
check_optional "ollama" "command -v ollama"
check_optional "antigravity (agy)" "command -v agy"
check_optional "hermes" "command -v hermes"

# AI Extensions
section "AI Extensions"
CLAUDE_SETTINGS="$HOME/.claude/settings.json"
check_optional "Claude enabledPlugins config" "[ -f \"$CLAUDE_SETTINGS\" ] && grep -q '\"enabledPlugins\"' \"$CLAUDE_SETTINGS\""
check_optional "Claude Codex plugin config" "[ -f \"$CLAUDE_SETTINGS\" ] && grep -q '\"codex@openai-codex\": true' \"$CLAUDE_SETTINGS\" && grep -q '\"openai-codex\"' \"$CLAUDE_SETTINGS\""
check_optional "Claude remember plugin config" "[ -f \"$CLAUDE_SETTINGS\" ] && grep -q '\"remember@claude-plugins-official\": true' \"$CLAUDE_SETTINGS\""
check_optional "oh-my-codex" "command -v omx"

# Skill Directories (단일 출처 ~/.skills + 도구별 symlink)
section "Skill Directories"
check_path "Shared skills (~/.skills)" "$HOME/.skills"
check_symlink "Claude skills -> ~/.skills" "$HOME/.claude/skills" "../.skills"
check_symlink "Codex skills (~/.agents) -> ~/.skills" "$HOME/.agents/skills" "../.skills"

# Agent Instructions
section "Agent Instructions"
check_path "Shared instructions" "$HOME/AGENTS.md"
check_symlink "Claude instructions -> ~/AGENTS.md" "$HOME/.claude/CLAUDE.md" "../AGENTS.md"
check_symlink "Codex instructions -> ~/AGENTS.md" "$HOME/.codex/AGENTS.md" "../AGENTS.md"
check_symlink "Copilot instructions -> ~/AGENTS.md" "$HOME/.copilot/copilot-instructions.md" "../AGENTS.md"

# Dotfiles
section "Dotfiles"
check_path ".zshrc" "$HOME/.zshrc"
check_path ".gitconfig" "$HOME/.gitconfig"
check_path ".vimrc" "$HOME/.vimrc"
check_path ".oh-my-zsh" "$HOME/.oh-my-zsh"

# Config
section "Config"
check_path "ghostty" "$HOME/.config/ghostty/config"
check_path "claude" "$HOME/.claude/settings.json"
check_path "codex" "$HOME/.codex/config.toml"
check_optional "copilot" "[ -f '$HOME/.copilot/mcp-config.json' ]"

# MCP
section "MCP"
check_optional ".claude.json" "[ -f '$HOME/.claude.json' ]"

# Summary
echo ""
echo "=== Summary ==="
echo -e "  ${GREEN}Pass: $pass${NC}  ${RED}Fail: $fail${NC}"

if [ "$fail" -eq 0 ]; then
    echo -e "\n${GREEN}All checks passed!${NC}"
else
    echo -e "\n${YELLOW}$fail item(s) need attention.${NC}"
    exit 1
fi
