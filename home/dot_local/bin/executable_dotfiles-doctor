#!/bin/bash
#
# dotfiles-doctor — Health check for dotfiles installation
# Usage: dotfiles-doctor

set -uo pipefail

GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

pass=0
fail=0

check() {
    local label="$1"
    local cmd="$2"
    if eval "$cmd" &>/dev/null; then
        echo -e "  ${GREEN}✓${NC} $label"
        pass=$((pass + 1))
    else
        echo -e "  ${RED}✗${NC} $label"
        fail=$((fail + 1))
    fi
}

check_optional() {
    local label="$1"
    local cmd="$2"
    if eval "$cmd" &>/dev/null; then
        echo -e "  ${GREEN}✓${NC} $label"
        pass=$((pass + 1))
    else
        echo -e "  ${YELLOW}○${NC} $label (optional)"
    fi
}

check_version() {
    local label="$1"
    local cmd="$2"
    if command -v "$(echo "$cmd" | awk '{print $1}')" &>/dev/null; then
        local ver
        ver=$(eval "$cmd" 2>/dev/null | head -1 || echo "unknown")
        echo -e "  ${GREEN}✓${NC} $label ($ver)"
        pass=$((pass + 1))
    else
        echo -e "  ${RED}✗${NC} $label"
        fail=$((fail + 1))
    fi
}

check_path() {
    local label="$1"
    local path="$2"
    if [ -e "$path" ]; then
        echo -e "  ${GREEN}✓${NC} $label"
        pass=$((pass + 1))
    else
        echo -e "  ${RED}✗${NC} $label — $path"
        fail=$((fail + 1))
    fi
}

section() {
    echo -e "\n${BLUE}[$1]${NC}"
}

echo "=== dotfiles-doctor ==="
echo "$(date '+%Y-%m-%d %H:%M:%S')"

# System
section "System"
OS=$(uname -s)
ARCH=$(uname -m)
if [ "$OS" = "Darwin" ]; then
    echo -e "  ${GREEN}✓${NC} macOS $(sw_vers -productVersion) ($ARCH)"
else
    echo -e "  ${GREEN}✓${NC} Linux $(uname -r) ($ARCH)"
fi
pass=$((pass + 1))

# Shell
section "Shell"
check_version "zsh" "zsh --version"
check_version "git" "git --version"
check_version "vim" "vim --version"
check "tmux" "command -v tmux"

# Terminal
section "Terminal"
check "ghostty" "command -v ghostty"

# Languages
section "Languages"
check_version "node" "node --version"
check_version "python3" "python3 --version"
check_version "go" "go version"
check_version "rustc" "rustc --version"
check_version "php" "php --version"
check_version "ruby" "ruby --version"

# Package Managers
section "Package Managers"
check "brew" "command -v brew"
check "zb" "command -v zb"
check "pipx" "command -v pipx"
check "bun" "command -v bun"

# AI CLI
section "AI CLI"
check "claude" "command -v claude"
check "codex" "command -v codex"
check_optional "codegraph" "command -v codegraph"
check_optional "ollama" "command -v ollama"
check_optional "antigravity (agy)" "command -v agy"
check_optional "hermes" "command -v hermes"

# AI Extensions
section "AI Extensions"
CLAUDE_SETTINGS="$HOME/.claude/settings.json"
check_optional "Claude enabledPlugins config" "[ -f \"$CLAUDE_SETTINGS\" ] && grep -q '\"enabledPlugins\"' \"$CLAUDE_SETTINGS\""
check_optional "Claude Codex plugin config" "[ -f \"$CLAUDE_SETTINGS\" ] && grep -q '\"codex@openai-codex\": true' \"$CLAUDE_SETTINGS\" && grep -q '\"openai-codex\"' \"$CLAUDE_SETTINGS\""
check_optional "Claude remember plugin config" "[ -f \"$CLAUDE_SETTINGS\" ] && grep -q '\"remember@claude-plugins-official\": true' \"$CLAUDE_SETTINGS\""
check_optional "oh-my-codex" "command -v omx"

# Skill Directories (단일 출처 ~/.skills + 도구별 symlink)
section "Skill Directories"
check_path "Shared skills (~/.skills)" "$HOME/.skills"
check "Claude skills -> ~/.skills" "[ -L '$HOME/.claude/skills' ] && [ -e '$HOME/.claude/skills' ]"
check "Codex skills (~/.agents) -> ~/.skills" "[ -L '$HOME/.agents/skills' ] && [ -e '$HOME/.agents/skills' ]"

# AGENTS.md
section "AGENTS.md"
check_path "~/AGENTS.md" "$HOME/AGENTS.md"

# Dotfiles
section "Dotfiles"
check_path "~/.zshrc" "$HOME/.zshrc"
check_path "~/.gitconfig" "$HOME/.gitconfig"
check_path "~/.vimrc" "$HOME/.vimrc"
check_path "~/.oh-my-zsh" "$HOME/.oh-my-zsh"

# Config
section "Config"
check_path "ghostty" "$HOME/.config/ghostty/config"
check_path "claude" "$HOME/.claude/settings.json"
check_path "codex" "$HOME/.codex/config.toml"

# MCP
section "MCP"
check_optional ".claude.json" "[ -f '$HOME/.claude.json' ]"

# Summary
echo ""
echo "=== Summary ==="
echo -e "  ${GREEN}Pass: $pass${NC}  ${RED}Fail: $fail${NC}"

if [ "$fail" -eq 0 ]; then
    echo -e "\n${GREEN}All checks passed!${NC}"
else
    echo -e "\n${YELLOW}$fail item(s) need attention.${NC}"
    exit 1
fi
