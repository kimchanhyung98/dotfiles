# 일반 alias 모음

# 파일 탐색 단축키
alias ll='ls -la'
alias la='ls -A'
alias l='ls -CF'

# Gemini CLI 단축키
alias gemini-yolo='gemini --approval-mode=yolo'

# Git 단축키
alias gs='git status'
alias ga='git add'
alias gc='git commit'
alias gp='git push'
alias gl='git pull'
alias gd='git diff'
alias gco='git checkout'
alias gb='git branch'
