# Ghostty 터미널 설정
# chezmoi로 관리 → ~/.config/ghostty/config

# - 폰트
font-family = D2Coding
font-size = 13.5
# 줄 간격 조정
adjust-cell-height = 1

# - 테마
theme = Gruvbox Dark

# - 커서
# 커서 깜빡임 비활성화
cursor-style-blink = false
# 타이핑 중 마우스 커서 숨김
mouse-hide-while-typing = true

# - 창 설정
# cmux가 자체 세로 탭을 제공 → ghostty 네이티브 탭바 숨김 (중복 제거)
window-show-tab-bar = never
# 좌우 패딩
window-padding-x = 8
# 상하 패딩
window-padding-y = 4
# 창 크기에 맞게 패딩 자동 균등 분배
window-padding-balance = true
# 배경 투명도
background-opacity = 0.8
# 배경 블러 강도
background-blur = 20
# 비활성 split 패널 투명도 (멀티 에이전트 패널 구분 강화)
unfocused-split-opacity = 0.65
# 비활성 split에 덧입히는 색 — Gruvbox 하드 다크로 더 어둡게 (테마 맞춤)
unfocused-split-fill = #1d2021
# split 구분선 색 — Gruvbox bg2
split-divider-color = #504945
# 탭/split 닫을 때 확인 다이얼로그 표시
confirm-close-surface = true
# 클립보드 붙여넣기 보호
clipboard-paste-protection = true

# - 셸 통합
shell-integration = zsh
# 스크롤백 버퍼 크기
scrollback-limit = 10000

{{ if eq .chezmoi.os "darwin" }}
# - macOS 전용
# macOS 레티나 디스플레이에서 텍스트 선명하게 표시
font-thicken = true
# Option 키를 Alt로 사용
macos-option-as-alt = true
{{ end }}
