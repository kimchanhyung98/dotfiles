# ~/.zshrc
# chezmoi로 관리

module_dir="$HOME/.config/zsh"
typeset -a zsh_modules=(
    "$module_dir/00-core.zsh"
    "$module_dir/10-env.zsh"
    "$module_dir/20-path.zsh"
    "$module_dir/30-functions.zsh"
    "$module_dir/40-completion.zsh"
    "$module_dir/50-plugins.zsh"
    "$module_dir/60-tools.zsh"
    "$module_dir/70-aliases.zsh"
    "$module_dir/80-secrets.zsh"
)

for module in "${zsh_modules[@]}"; do
    if [ -r "$module" ]; then
        source "$module"
    fi
done

unset module module_dir zsh_modules
